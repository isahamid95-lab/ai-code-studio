# AI Code Studio Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# REQUIRED: Alibaba/Qwen AI (Primary AI)
# ============================================
VITE_ALIBABA_API_KEY=your_alibaba_api_key_here
VITE_ALIBABA_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/v1

# ============================================
# OPTIONAL: Google Gemini AI (Alternative)
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# OPTIONAL: Morph MCP (Advanced features)
# ============================================
MORPH_API_KEY=your_morph_api_key_here

# ============================================
# RENDER DEPLOY GUIDE
# ============================================
# 1. Push this repo to GitHub
# 2. Go to render.com and sign up/login
# 3. Click "New" -> "Blueprint"
# 4. Connect your GitHub repo
# 5. Render will detect render.yaml
# 6. Add your API keys in Environment Variables
# 7. Click "Apply" to deploy
#
# IMPORTANT: Add these secrets in Render Dashboard:
# - VITE_ALIBABA_API_KEY
# - GEMINI_API_KEY (optional)
# - MORPH_API_KEY (optional)